# Environment Configuration for Dying Star Launcher

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
NODE_ENV=development

# Electron Configuration (process Node — pour electron en CLI, pas pour le code bundlé)
#ELECTRON_DISABLE_SECURITY_WARNINGS=true

# ===========================================
# BUILD SETTINGS
# ===========================================
# Set to 'production' when building for release
# NODE_ENV=production

# Disable security warnings in production (not recommended)
# ELECTRON_DISABLE_SECURITY_WARNINGS=false

# ===========================================
# ENVIRONMENTS
# ===========================================
# Prod
VITE_API_BASE_UNIVERSE=
# Test
VITE_API_BASE_TESTING=https://dyingstar-game.com

# Env **universe** (prod) : URLs complètes des archives (prioritaires sur /game/latest-*.zip).
# VITE_GAME_ZIP_LINUX=
# VITE_GAME_ZIP_WINDOWS=
# VITE_GAME_ZIP_DARWIN=

# Env **universe-testing** : URLs complètes des archives (prioritaires sur /game/latest-*.zip).
VITE_GAME_ZIP_TESTING_LINUX=https://dyingstar-game.com/DyingStar-linux-testing.zip
VITE_GAME_ZIP_TESTING_WINDOWS=https://dyingstar-game.com/DyingStar-windows-testing.zip
# VITE_GAME_ZIP_TESTING_DARWIN=

# Dépôt GitHub du launcher — utilisé pour comparer app.getVersion() à la dernière release.
# Si vide ou aucune release : pas de bandeau « mise à jour launcher ».
VITE_LAUNCHER_GITHUB_REPO_URL=https://github.com/DyingStar-game/launcher

# Salon Discord pour récupérer la nouvelle version du launcher
VITE_LAUNCHER_RELEASE_DISCORD_URL=https://discord.com/channels/1399325839665004554/1503113659184971898

# Barre de navigation (renderer) — vide → bouton désactivé.
VITE_NAV_WEBSITE_URL=https://dyingstar-game.com
VITE_NAV_DISCORD_URL=https://discord.gg/geWRctZfMn
VITE_NAV_WIKI_URL=https://codex.dyingstar-game.com/
VITE_NAV_DONATE_URL=

# Pages de statut (une par env). Si vide → bouton « voir le statut » désactivé.
# Prod : à renseigner quand l’URL est connue.
VITE_STATUS_PAGE_UNIVERSE=
VITE_STATUS_PAGE_TESTING=https://status.dyingstar-game.com

# Rafraîchissement automatique du statut serveur et du nombre de joueurs (minutes)
VITE_SERVER_STATUS_POLL_MINUTES=5

# ===========================================
# DEBUG SETTINGS
# ===========================================
# Enable detailed Electron debugging
DEBUG_ELECTRON=false

# ===========================================
# OPTIONAL SETTINGS (main — préfixe VITE_ pour inclusion dans le binaire)
# ===========================================
VITE_WINDOW_WIDTH=1200
VITE_WINDOW_HEIGHT=800

# DevTools au lancement — en prod, laisser false ou absent
VITE_ENABLE_DEVTOOLS=true

# Logs fichier au niveau debug
VITE_ELECTRON_ENABLE_LOGGING=true

# ===========================================
# HTTP / DOWNLOAD / GAME (main process)
# ===========================================
# Timeouts in milliseconds
# VITE_HTTP_TIMEOUT_API_MS=8000
# VITE_HTTP_TIMEOUT_VERSION_PING_MS=5000
# VITE_HTTP_TIMEOUT_GITHUB_MS=10000
# VITE_DOWNLOAD_TIMEOUT_MS=600000
# VITE_GAME_PROCESS_POLL_MS=2000

# Optional download host (defaults to API base when empty)
# VITE_GAME_DOWNLOAD_BASE_UNIVERSE=
# VITE_GAME_DOWNLOAD_BASE_TESTING=

# Cachet status API ids (defaults: component 3, metric 2)
# VITE_STATUS_COMPONENT_ID_UNIVERSE=3
# VITE_STATUS_COMPONENT_ID_TESTING=3
# VITE_STATUS_METRIC_ID_UNIVERSE=2
# VITE_STATUS_METRIC_ID_TESTING=2

# Game install layout
# VITE_GAME_INSTALL_SUBDIR=DyingStar
# VITE_GAME_EXE_WINDOWS=DyingStar.exe
# VITE_GAME_EXE_LINUX=DyingStar.x86_64
# VITE_GAME_EXE_DARWIN=DyingStar.app

# OAuth / custom protocol
# VITE_APP_PROTOCOL=dyingstar
# VITE_AUTH_CLIENT_ID=dyingstar-launcher
# VITE_AUTH_REALM=dyingstar
# VITE_AUTH_REDIRECT_URI=dyingstar://auth/callback
# VITE_DOWNLOAD_USER_AGENT=DyingStar-Launcher/1.0

# Window max size when auto-fitting content
# VITE_WINDOW_MAX_WIDTH=1920
# VITE_WINDOW_MAX_HEIGHT=1200

# ===========================================
# UI TIMING (renderer)
# ===========================================
# VITE_UI_TOAST_DURATION_MS=3800
# VITE_UI_SOCIAL_PANEL_CLOSE_MS=1200

